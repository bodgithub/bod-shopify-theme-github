{% render 'plan-selector', s: section.settings, uid: section.id %}
{% schema %}
{
  "name": "Plan selector (v2)",
  "tag": "section",
  "class": "section-plan-selector-v2",
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Card style",
      "default": "bordered",
      "options": [
        {
          "value": "bordered",
          "label": "A · Gradient border"
        },
        {
          "value": "clean",
          "label": "B · Clean white + accents"
        },
        {
          "value": "expanded",
          "label": "C · Stacked expanded"
        }
      ]
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Gradient border width",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "px",
      "default": 5
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 360,
      "max": 720,
      "step": 20,
      "unit": "px",
      "default": 560
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (blue)",
      "default": "#1B3DEF"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title ink",
      "default": "#14307C"
    },
    {
      "type": "color",
      "id": "deep_color",
      "label": "Gradient deep stop",
      "default": "#0E2160"
    },
    {
      "type": "color",
      "id": "serving_color",
      "label": "Serving + billed-line colour",
      "default": "#1B3DEF"
    },
    {
      "type": "checkbox",
      "id": "serving_caps",
      "label": "Serving + billed-line UPPERCASE",
      "default": true
    },
    {
      "type": "header",
      "content": "Copy & cart"
    },
    {
      "type": "text",
      "id": "adding_label",
      "label": "Button — adding state",
      "default": "Adding…"
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote",
      "default": "Cancel or pause anytime. Free shipping on subscriptions."
    },
    {
      "type": "text",
      "id": "gifts_label",
      "label": "Gift tiles row label",
      "default": "Free gifts included"
    },
    {
      "type": "range",
      "id": "gift_width",
      "label": "Gift tile width",
      "min": 70,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Plan 1"
    },
    {
      "type": "text",
      "id": "p1_name",
      "label": "Name",
      "default": "3-Month Bundle"
    },
    {
      "type": "text",
      "id": "p1_cadence",
      "label": "Cadence",
      "default": "Ships every 3 months · cancel anytime"
    },
    {
      "type": "text",
      "id": "p1_price",
      "label": "Price",
      "default": "$0"
    },
    {
      "type": "text",
      "id": "p1_compare",
      "label": "Compare-at"
    },
    {
      "type": "select",
      "id": "p1_banner_type",
      "label": "Banner",
      "default": "popular",
      "options": [
        {
          "value": "popular",
          "label": "Accent"
        },
        {
          "value": "value",
          "label": "Deep"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    {
      "type": "text",
      "id": "p1_banner_label",
      "label": "Banner label",
      "default": "Most Popular"
    },
    {
      "type": "text",
      "id": "p1_save",
      "label": "SAVE badge"
    },
    {
      "type": "html",
      "id": "p1_spec",
      "label": "Spec line",
      "info": "<b>=blue, <span class='dot'>·</span>=separator",
      "default": "40:1 <b>MYO : DCI</b><span class='dot'>·</span>HPLC-verified"
    },
    {
      "type": "textarea",
      "id": "p1_benefits",
      "label": "Benefits (one per line)",
      "default": "Supports healthy insulin sensitivity\nPause, skip or cancel anytime\nFree shipping on every delivery"
    },
    {
      "type": "text",
      "id": "p1_variant",
      "label": "Product variant ID"
    },
    {
      "type": "text",
      "id": "p1_plan",
      "label": "ReCharge selling-plan ID",
      "info": "Blank = one-time purchase."
    },
    {
      "type": "number",
      "id": "p1_qty",
      "label": "Quantity",
      "default": 1
    },
    {
      "type": "text",
