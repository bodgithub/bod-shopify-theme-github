{% comment %}
  Bodology · "How inositol works" — Option E
  Apple × Hims · warm, photo-led, benefit-first.

  Everything is editable in the theme editor: background (solid OR gradient),
  optional full-width background image + opacity, the side photo, all text
  colours (headline, italic accent word, eyebrow pill, intro, benefits,
  caption), spacing, layout side, and the benefit blocks (up to 6).

  FONTS: uses the theme's brand fonts:
    --font-sans  → Tenon  (Adobe Fonts / Typekit — loaded in theme.liquid)
    --font-serif → Instrument Serif (Google Fonts — loaded below as a fallback)
{% endcomment %}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap">

{%- liquid
  assign s = section.settings
  assign img_op = s.bg_image_opacity | default: 100 | divided_by: 100.0
-%}

{% style %}
  #shopify-section-{{ section.id }} .hiw { position: relative; background: {{ s.bg_color | default: '#F3EEEA' }}; padding: {{ s.padding_top | default: 84 }}px 0 {{ s.padding_bottom | default: 84 }}px; overflow: hidden; }
  #shopify-section-{{ section.id }} .hiw__bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: {{ img_op }}; z-index: 0; pointer-events: none; }
  #shopify-section-{{ section.id }} .hiw-wrap { position: relative; z-index: 1; max-width: 1140px; margin: 0 auto; padding: 0 28px; display: grid; grid-template-columns: 1fr; gap: 36px; align-items: stretch; }
  #shopify-section-{{ section.id }} .hiw-media { position: relative; border-radius: 28px; overflow: hidden; min-height: 440px; box-shadow: 0 30px 70px rgba(60,40,20,0.16); }
  #shopify-section-{{ section.id }} .hiw-media img { width: 100%; height: 100%; object-fit: cover; object-position: center {{ s.image_focus | default: 18 }}%; display: block; }
  #shopify-section-{{ section.id }} .hiw-cap { position: absolute; left: 18px; right: 18px; bottom: 18px; display: flex; align-items: center; gap: 11px; background: rgba(255,255,255,0.72); -webkit-backdrop-filter: blur(16px); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.6); border-radius: 16px; padding: 13px 16px; font-size: 13.5px; line-height: 1.35; color: {{ s.caption_color | default: '#000000' }}; }
  #shopify-section-{{ section.id }} .hiw-cap .dot { width: 9px; height: 9px; border-radius: 50%; background: {{ s.icon_color | default: '#1B3DEF' }}; flex-shrink: 0; }
  #shopify-section-{{ section.id }} .hiw-pill { display: inline-flex; align-items: center; gap: 8px; white-space: nowrap; background: {{ s.pill_bg | default: '#FFFFFF' }}; color: {{ s.pill_text_color | default: '#1B3DEF' }}; border: 1px solid {{ s.pill_border | default: '#1B3DEF' }}; border-radius: 999px; padding: 8px 16px; font-family: var(--font-sans, 'tenon', sans-serif); font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 22px; }
  #shopify-section-{{ section.id }} .hiw-h { font-family: var(--font-sans, 'tenon', sans-serif); font-weight: 600; letter-spacing: -0.03em; line-height: 1.04; font-size: clamp(34px, 4.6vw, 60px); color: {{ s.heading_color | default: '#000000' }}; margin: 0; text-wrap: balance; }
  #shopify-section-{{ section.id }} .hiw-h p { margin: 0; }
  #shopify-section-{{ section.id }} .hiw-h em { font-family: var(--font-serif, 'Instrument Serif', serif); font-style: italic; font-weight: 400; color: {{ s.marker_color | default: '#1B3DEF' }}; letter-spacing: 0; }
  #shopify-section-{{ section.id }} .hiw-lede { font-family: var(--font-sans, 'tenon', sans-serif); font-size: 18px; line-height: 1.55; color: {{ s.lede_color | default: '#5C5651' }}; margin: 18px 0 0; max-width: 46ch; }
  #shopify-section-{{ section.id }} .hiw-list { margin-top: 32px; display: flex; flex-direction: column; }
  #shopify-section-{{ section.id }} .hiw-item { display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: start; padding: 22px 0; border-top: 1px solid {{ s.divider_color | default: 'rgba(60,40,20,0.12)' }}; }
  #shopify-section-{{ section.id }} .hiw-item:last-child { border-bottom: 1px solid {{ s.divider_color | default: 'rgba(60,40,20,0.12)' }}; }
  #shopify-section-{{ section.id }} .hiw-ico { width: 48px; height: 48px; border-radius: 50%; background: {{ s.icon_bg | default: '#FFFFFF' }}; border: 1px solid rgba(60,40,20,0.08); color: {{ s.icon_color | default: '#1B3DEF' }}; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 16px rgba(60,40,20,0.08); flex-shrink: 0; }
  #shopify-section-{{ section.id }} .hiw-ico svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
  #shopify-section-{{ section.id }} .hiw-it-h { font-family: var(--font-sans, 'tenon', sans-serif); font-weight: 600; font-size: 18px; letter-spacing: -0.01em; color: {{ s.benefit_title_color | default: '#000000' }}; margin: 3px 0 5px; }
  #shopify-section-{{ section.id }} .hiw-it-b { font-family: var(--font-sans, 'tenon', sans-serif); font-size: 15px; line-height: 1.5; color: {{ s.benefit_body_color | default: '#5C5651' }}; margin: 0; }
  @media (min-width: 900px) {
    #shopify-section-{{ section.id }} .hiw-wrap { grid-template-columns: 0.9fr 1.1fr; gap: 64px; align-items: center; }
    #shopify-section-{{ section.id }} .hiw-media { min-height: 600px; height: 100%; }
    {% if s.image_side == 'right' %}
      #shopify-section-{{ section.id }} .hiw-media { order: 2; }
    {% endif %}
  }
{% endstyle %}

<section class="hiw">
  {%- if s.bg_image != blank -%}
    <div class="hiw__bg" style="background-image: url('{{ s.bg_image | image_url: width: 2200 }}');"></div>
  {%- endif -%}

  <div class="hiw-wrap">

    <div class="hiw-media">
      {% if s.image %}
        {{ s.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: s.image.alt | default: s.heading }}
      {% else %}
        <img src="{{ 'model-drink.png' | asset_url }}" alt="{{ s.heading | strip_html | strip }}" loading="lazy">
      {% endif %}
      {% if s.caption != blank %}
        <div class="hiw-cap"><span class="dot"></span>{{ s.caption }}</div>
      {% endif %}
    </div>

    <div class="hiw-content">
      {% if s.pill_text != blank %}
        <span class="hiw-pill">{{ s.pill_text }}</span>
      {% endif %}
      <h2 class="hiw-h">{{ s.heading }}</h2>
      {% if s.lede != blank %}
        <p class="hiw-lede">{{ s.lede }}</p>
      {% endif %}

      <div class="hiw-list">
        {% for block in section.blocks %}
          <div class="hiw-item" {{ block.shopify_attributes }}>
            <div class="hiw-ico">
              {%- case block.settings.icon -%}
                {%- when 'signal' -%}<svg viewBox="0 0 24 24"><path d="M2.5 13h3.4l2.3-7.5L12 19l2.2-8 1.6 4h5.7"/></svg>
                {%- when 'cycle' -%}<svg viewBox="0 0 24 24"><path d="M20.5 12a8.5 8.5 0 0 1-14.6 5.9"/><path d="M3.5 12A8.5 8.5 0 0 1 18.1 6.1"/><path d="M18.5 2.5v4h-4"/><path d="M5.5 21.5v-4h4"/></svg>
                {%- when 'tune' -%}<svg viewBox="0 0 24 24"><path d="M5 21v-7M5 10V3M12 21v-5M12 12V3M19 21v-9M19 8V3"/><circle cx="5" cy="12" r="2"/><circle cx="12" cy="10" r="2"/><circle cx="19" cy="6" r="2"/></svg>
                {%- when 'heart' -%}<svg viewBox="0 0 24 24"><path d="M12 20.4S4.3 15.9 4.3 9.9A3.9 3.9 0 0 1 12 7.2a3.9 3.9 0 0 1 7.7 2.7c0 6-7.7 10.5-7.7 10.5z"/></svg>
                {%- else -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/></svg>
              {%- endcase -%}
            </div>
            <div>
              <h3 class="hiw-it-h">{{ block.settings.title }}</h3>
              <p class="hiw-it-b">{{ block.settings.body }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "How inositol works",
  "tag": "section",
  "class": "section-how-inositol-works",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "image_side", "label": "Image side (desktop)", "default": "left",
      "options": [ { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ] },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 84 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 84 },

    { "type": "header", "content": "Background" },
    { "type": "color_background", "id": "bg_color", "label": "Background (solid or gradient)", "default": "#F3EEEA" },
    { "type": "image_picker", "id": "bg_image", "label": "Full-width background image", "info": "Optional. Sits behind everything, full width." },
    { "type": "range", "id": "bg_image_opacity", "label": "Background image opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },

    { "type": "header", "content": "Side photo" },
    { "type": "image_picker", "id": "image", "label": "Photo", "info": "Falls back to model-drink.png in assets if left empty." },
    { "type": "range", "id": "image_focus", "label": "Vertical focus", "min": 0, "max": 100, "step": 2, "unit": "%", "default": 18 },
    { "type": "text", "id": "caption", "label": "Photo caption", "default": "One scoop, stirred into your morning coffee or water." },
    { "type": "color", "id": "caption_color", "label": "Caption text", "default": "#000000" },

    { "type": "header", "content": "Eyebrow pill" },
    { "type": "text", "id": "pill_text", "label": "Eyebrow label", "default": "Why it works" },
    { "type": "color", "id": "pill_bg", "label": "Pill background", "default": "#FFFFFF" },
    { "type": "color", "id": "pill_text_color", "label": "Pill text", "default": "#1B3DEF" },
    { "type": "color", "id": "pill_border", "label": "Pill border", "default": "#1B3DEF" },

    { "type": "header", "content": "Heading" },
    { "type": "richtext", "id": "heading", "label": "Heading", "info": "Wrap a word in italics to render it in the serif accent.", "default": "<p>Feel it work, from the <em>inside out</em></p>" },
    { "type": "color", "id": "heading_color", "label": "Heading text", "default": "#000000" },
    { "type": "color", "id": "marker_color", "label": "Italic accent word", "default": "#1B3DEF" },
    { "type": "textarea", "id": "lede", "label": "Intro line", "default": "Inositol works upstream on insulin — so the steadier energy, calmer cycles and better mood follow naturally." },
    { "type": "color", "id": "lede_color", "label": "Intro text", "default": "#5C5651" },

    { "type": "header", "content": "Benefits" },
    { "type": "color", "id": "benefit_title_color", "label": "Benefit title", "default": "#000000" },
    { "type": "color", "id": "benefit_body_color", "label": "Benefit body", "default": "#5C5651" },
    { "type": "color", "id": "icon_color", "label": "Icon", "default": "#1B3DEF" },
    { "type": "color", "id": "icon_bg", "label": "Icon circle background", "default": "#FFFFFF" },
    { "type": "color", "id": "divider_color", "label": "Divider line", "default": "#E6DED5" }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Benefit",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "signal",
          "options": [
            { "value": "signal", "label": "Signal / energy" },
            { "value": "cycle", "label": "Cycle" },
            { "value": "tune", "label": "Regulate / tune" },
            { "value": "heart", "label": "Mood / heart" }
          ] },
        { "type": "text", "id": "title", "label": "Title", "default": "Steadier energy, all day" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Supports a healthy insulin response, so blood sugar stays even — fewer highs and lows." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "How inositol works",
      "blocks": [
        { "type": "pillar", "settings": { "icon": "signal", "title": "Steadier energy, all day", "body": "Supports a healthy insulin response, so blood sugar stays even — fewer highs and lows." } },
        { "type": "pillar", "settings": { "icon": "cycle", "title": "Cycles you can count on", "body": "Backs the ovarian function behind a more regular, more predictable cycle." } },
        { "type": "pillar", "settings": { "icon": "tune", "title": "Fewer cravings", "body": "Smooths the blood-sugar dips that set off cravings and afternoon crashes." } },
        { "type": "pillar", "settings": { "icon": "heart", "title": "A calmer mood", "body": "Part of the signaling that keeps mood and emotions on a more even keel." } }
      ]
    }
  ]
}
{% endschema %}
