    "bod_standards": {
      "type": "custom-liquid",
      "name": "Standards",
      "settings": {
        "custom_liquid": "<section class=\"bx bx--soft\">\n  <div class=\"bx__container bx__container--narrow\">\n    <header class=\"bx__head\">\n      <p class=\"bx__eyebrow\">Our standards</p>\n      <h2 class=\"bx__title\">Quality + formulation, <em>without compromise</em></h2>\n      <p class=\"bx__lead\">Every decision is grounded in peer-reviewed research and validated by health professionals.</p>\n    </header>\n    <div class=\"bx-acc\">\n      <details class=\"bx-acc__item\"><summary>Clinically-informed formulation</summary><div class=\"bx-acc__c\"><p>Our formula was built from the ground up using published clinical studies and reviewed by experts in metabolic health, PCOS, and fertility. We chose the 40:1 ratio because it’s the most effective — and we stuck to the science, not the hype.</p></div></details>\n      <details class=\"bx-acc__item\"><summary>Expert validation at every step</summary><div class=\"bx-acc__c\"><p>Our advisors review our claims, confirm our dosages, and approve every Certificate of Analysis for ingredient purity. Real oversight — not rubber stamps.</p></div></details>\n      <details class=\"bx-acc__item\"><summary>Purity that meets clinical standards</summary><div class=\"bx-acc__c\"><p>We benchmark against pharmacopoeial purity standards, sourcing ingredients that meet or exceed these thresholds — verified by Certificates of Analysis and third-party labs. It’s part of keeping Bodology pure, transparent, and trustworthy.</p></div></details>\n      <details class=\"bx-acc__item\"><summary>Third-party tested in the USA</summary><div class=\"bx-acc__c\"><p>Every batch is manufactured in an FDA-compliant facility and undergoes rigorous third-party testing for identity, potency, and purity — so you get exactly what’s on the label.</p></div></details>\n    </div>\n  </div>\n</section>"
      }
    },
    "trust_strip_A4VndW": {
      "type": "trust-strip",
      "name": "Trust strip",
      "settings": {
        "headline": "Every batch, independently verified",
        "headline_size": 21,
        "headline_weight": "600",
        "headline_color": "#14307C",
        "style": "white",
        "center_all": true,
        "frame_flat": true,
        "title_color": "#14307C",
        "sub_color": "#42579E",
        "max_width": 720,
        "padding_top": 16,
        "padding_bottom": 16,
        "b1_enable": true,
        "b1_icon": "expert",
        "b1_title": "Expert Reviewed",
        "b1_sub": "RD • MS • PhD",
        "b1_tip": "<p>Bodology's formula and label are reviewed by qualified professionals — including a <strong>Registered Dietitian (RD)</strong> and advisors holding <strong>MS and PhD</strong> credentials — so the ingredients, doses, and claims are accurate and responsibly stated.</p>",
        "b2_enable": true,
        "b2_icon": "flask",
        "b2_title": "Third Party Tested",
        "b2_sub": "ISO/IEC 17025 Accredited Labs",
        "b2_tip": "<p>Bodology is tested independently — we don't grade our own work. Every production batch is sent to <strong>Certified Laboratories</strong>, an ISO/IEC 17025-accredited testing lab, and analyzed against written specifications before it can be sold. ISO/IEC 17025 is the international standard for laboratory competence and data integrity.</p>",
        "b3_enable": true,
        "b3_icon": "fingerprint",
        "b3_title": "Identity Verified",
        "b3_sub": "HPLC Analytical Testing",
        "b3_tip": "<p>We use <strong>HPLC analytical testing</strong> to confirm the identity of each active — verifying that what's in the tub is genuinely myo-inositol and D-chiro-inositol, not a substitute or mislabeled material.</p>",
        "b4_enable": true,
        "b4_icon": "chart",
        "b4_title": "Potency Confirmed",
        "b4_sub": "Myo & D-Chiro Inositol Verified",
        "b4_tip": "<p>HPLC confirms that each batch contains <strong>myo-inositol and D-chiro-inositol at the labeled amounts</strong> — and that the 40:1 ratio is correct in the finished powder, not only in the formula. Because the two are isomers, HPLC separates and measures each one individually.</p>",
        "b5_enable": true,
        "b5_icon": "shield",
        "b5_title": "Heavy Metal Tested",
        "b5_sub": "Arsenic • Cadmium • Mercury • Lead",
        "b5_tip": "<p>Every batch is tested for heavy metals by <strong>ICP-MS</strong> — arsenic, cadmium, mercury, and lead — and must fall within established safety limits before release. ICP-MS detects these metals down to trace levels, well below the limits set for dietary supplements.</p>",
        "b6_enable": true,
        "b6_icon": "microbe",
