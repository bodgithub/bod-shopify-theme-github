      "settings": {
        "custom_liquid": "<style>\n/* ===== Bodology experts page — design system ===== */\n.bx{padding:clamp(56px,8vw,100px) 0;background:linear-gradient(165deg,#142cb8 0%,#1b3def 45%,#3a55ff 100%);background-attachment:fixed;}\n.bx--soft{}\n.bx__container{max-width:1120px;margin:0 auto;padding:0 24px;}\n.bx__container--narrow{max-width:860px;}\n.bx__head{text-align:center;max-width:720px;margin:0 auto clamp(36px,5vw,56px);}\n.bx__eyebrow{margin:0 0 14px;font-size:13px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.85);}\n.bx__title{margin:0 0 18px;font-size:clamp(40px,6.5vw,76px);line-height:1.02;color:#fff;font-weight:700;letter-spacing:-.01em;}\n.bx__title em{font-style:italic;}\n.bx__lead{margin:0;font-size:clamp(16px,1.7vw,19px);line-height:1.6;color:#fff;opacity:.9;}\n/* hero */\n.bx--hero{color:#fff;padding:clamp(84px,13vw,168px) 0;}\n.bx-hero__inner{text-align:center;max-width:820px;margin:0 auto;}\n.bx-hero__eyebrow{margin:0 0 16px;font-size:12px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.78);}\n.bx-hero__title{margin:0 0 22px;font-size:clamp(48px,8vw,92px);line-height:1;font-weight:700;color:#fff;letter-spacing:-.02em;}\n.bx-hero__title em{font-style:italic;}\n.bx-hero__lead{margin:0 auto 34px;max-width:580px;font-size:clamp(16px,1.8vw,19px);line-height:1.6;color:#fff;opacity:.92;}\n.bx-hero__actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}\n/* buttons */\n.bx-btn{display:inline-block;padding:15px 36px;border-radius:999px;font-weight:700;font-size:15px;text-decoration:none;transition:transform .25s ease,background .25s ease,border-color .25s ease;}\n.bx-btn--light{background:#fff;color:#1b3def;}\n.bx-btn--light:hover{transform:translateY(-2px);background:#f3eeeb;}\n.bx-btn--ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.55);}\n.bx-btn--ghost:hover{transform:translateY(-2px);border-color:#fff;}\n/* pillars */\n.bx-pillars{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}\n@media(max-width:900px){.bx-pillars{grid-template-columns:repeat(2,1fr);}}\n@media(max-width:540px){.bx-pillars{grid-template-columns:1fr;}}\n.bx-pillar{background:#fff;border:1px solid #e6e9f5;border-radius:18px;padding:28px 24px;}\n.bx-pillar__n{font-size:13px;font-weight:700;color:#1b3def;letter-spacing:.05em;}\n.bx-pillar__t{margin:12px 0 10px;font-size:15px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#1b3def;}\n.bx-pillar__d{margin:0;font-size:14.5px;line-height:1.6;color:#2c2d2e;opacity:.85;}\n/* accordion */\n.bx-acc{display:flex;flex-direction:column;gap:12px;}\n.bx-acc__item{background:#fff;border:1px solid #e6e9f5;border-radius:16px;padding:4px 24px;}\n.bx-acc__item summary{cursor:pointer;list-style:none;display:flex;align-items:center;padding:20px 0;font-size:16px;font-weight:700;color:#1b3def;}\n.bx-acc__item summary::-webkit-details-marker{display:none;}\n.bx-acc__item summary::after{content:\"+\";margin-left:auto;padding-left:16px;font-size:22px;line-height:1;color:#1b3def;transition:transform .3s ease;}\n.bx-acc__item[open] summary::after{transform:rotate(45deg);}\n.bx-acc__c{padding:0 0 22px;font-size:15px;line-height:1.65;color:#2c2d2e;opacity:.88;}\n.bx-acc__c p{margin:0;}\n/* cta */\n.bx-cta{background:#fff;border:1px solid #e0e5f6;border-radius:28px;padding:clamp(48px,7vw,84px) 28px;text-align:center;color:#2c2d2e;box-shadow:0 30px 70px rgba(19,28,90,.22);}\n.bx-cta__eyebrow{margin:0 0 14px;font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#1b3def;}\n.bx-cta__title{margin:0 0 14px;font-size:clamp(32px,4.5vw,56px);line-height:1.05;color:#1b3def;letter-spacing:-.01em;}\n.bx-cta__text{margin:0 auto 30px;max-width:520px;font-size:16px;line-height:1.6;color:#2c2d2e;opacity:.82;}\n.bx-cta__btn{display:inline-block;background:#1b3def;color:#fff;font-weight:700;padding:16px 42px;border-radius:999px;text-decoration:none;transition:transform .25s ease,background .25s ease;}\n.bx-cta__btn:hover{transform:translateY(-2px);background:#142cb8;}\n</style>\n<section class=\"bx bx--hero\">\n  <div class=\"bx__container\">\n    <div class=\"bx-hero__inner\">\n      <p class=\"bx-hero__eyebrow\">The experts behind Bodology</p>\n      <h1 class=\"bx-hero__title\">Backed by <em>science</em>.<br>Guided by <em>experts</em>.</h1>\n      <p class=\"bx-hero__lead\">Your metabolism powers everything — hormones, mood, fertility. Every scoop of Bodology is shaped by the experts who understand how it all connects.</p>\n      <div class=\"bx-hero__actions\">\n        <a class=\"bx-btn bx-btn--light\" href=\"#experts\">Meet the team</a>\n        <a class=\"bx-btn bx-btn--ghost\" href=\"/products/myo-d-chiro-inositol-powder\">Shop inositol</a>\n      </div>\n    </div>\n  </div>\n</section>"
      }
