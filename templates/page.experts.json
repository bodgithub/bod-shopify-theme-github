      "type": "custom-liquid",
      "name": "CTA",
      "settings": {
        "custom_liquid": "<section class=\"bx\">\n  <div class=\"bx__container\">\n    <div class=\"bx-cta\">\n      <p class=\"bx-cta__eyebrow\">Backed by experts. Built for you.</p>\n      <h2 class=\"bx-cta__title\">Support your body trusts</h2>\n      <p class=\"bx-cta__text\">Clean, clinically-informed inositol — formulated alongside the experts who guide our science.</p>\n      <a class=\"bx-cta__btn\" href=\"/products/myo-d-chiro-inositol-powder\">Shop inositol</a>\n    </div>\n  </div>\n</section>"
