iv class=\"bx-modal\" id=\"bx-modal-c-dr-anita\" role=\"dialog\" aria-modal=\"true\">\n      <div class=\"bx-modal__overlay\"></div>\n      <div class=\"bx-modal__box\">\n        <button class=\"bx-modal__close\" type=\"button\" aria-label=\"Close\">&times;</button>\n        <div class=\"bx-modal__photo\">{%- if e.expert_photo.value != blank -%}{{ e.expert_photo.value | image_url: width: 800 | image_tag: loading: 'lazy', alt: e.expert_name.value }}{%- endif -%}</div>\n        <h3 class=\"bx-modal__name\">{{ e.expert_name.value }}</h3>\n        <p class=\"bx-modal__role\">{{ e.expert_title.value }}</p>\n        <div class=\"bx-modal__bio\">{{ e.bio | metafield_tag }}</div>\n      </div>\n    </div>\n    {%- assign e = metaobjects.experts[\"leslie-kutcha-fdnp\"] -%}\n    <div class=\"bx-modal\" id=\"bx-modal-leslie-kutcha-fdnp\" role=\"dialog\" aria-modal=\"true\">\n      <div class=\"bx-modal__overlay\"></div>\n      <div class=\"bx-modal__box\">\n        <button class=\"bx-modal__close\" type=\"button\" aria-label=\"Close\">&times;</button>\n        <div class=\"bx-modal__photo\">{%- if e.expert_photo.value != blank -%}{{ e.expert_photo.value | image_url: width: 800 | image_tag: loading: 'lazy', alt: e.expert_name.value }}{%- endif -%}</div>\n        <h3 class=\"bx-modal__name\">{{ e.expert_name.value }}</h3>\n        <p class=\"bx-modal__role\">{{ e.expert_title.value }}</p>\n        <div class=\"bx-modal__bio\">{{ e.bio | metafield_tag }}</div>\n      </div>\n    </div>\n    {%- assign e = metaobjects.experts[\"a-hillary-rd\"] -%}\n    <div class=\"bx-modal\" id=\"bx-modal-a-hillary-rd\" role=\"dialog\" aria-modal=\"true\">\n      <div class=\"bx-modal__overlay\"></div>\n      <div class=\"bx-modal__box\">\n        <button class=\"bx-modal__close\" type=\"button\" aria-label=\"Close\">&times;</button>\n        <div class=\"bx-modal__photo\">{%- if e.expert_photo.value != blank -%}{{ e.expert_photo.value | image_url: width: 800 | image_tag: loading: 'lazy', alt: e.expert_name.value }}{%- endif -%}</div>\n        <h3 class=\"bx-modal__name\">{{ e.expert_name.value }}</h3>\n        <p class=\"bx-modal__role\">{{ e.expert_title.value }}</p>\n        <div class=\"bx-modal__bio\">{{ e.bio | metafield_tag }}</div>\n      </div>\n    </div>\n<style>\n/* hero polish (native overlay section) */\n.image-with-text-overlay .h1-xlarge{line-height:1.05;}\n.image-with-text-overlay--content-inner .button{margin:8px 6px 0;}\n/* expert cards */\n.bxg{max-width:1120px;margin:0 auto;padding:8px 24px 0;}\n.bx-ex__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:24px;}\n@media(max-width:520px){.bx-ex__grid{grid-template-columns:1fr;}}\n.bx-ex__card{position:relative;display:flex;background:linear-gradient(135deg,#eef1fc 0%,#e1e8fb 100%);border:1px solid #e0e5f6;border-radius:18px;overflow:hidden;min-height:210px;}\n.bx-ex__photo{flex:0 0 42%;max-width:42%;background:#e7ebfa;}\n.bx-ex__img,.bx-ex__ph{width:100%;height:100%;object-fit:cover;display:block;}\n.bx-ex__ph{background:linear-gradient(135deg,#e7ebfa,#d4ddf6);}\n.bx-ex__info{flex:1;padding:26px 24px 60px;display:flex;flex-direction:column;}\n.bx-ex__name{margin:0 0 8px;font-size:19px;font-weight:700;color:#1b3def;line-height:1.25;}\n.bx-ex__role{margin:0;font-size:14px;line-height:1.5;color:#2c2d2e;opacity:.75;}\n.bx-ex__open{position:absolute;right:18px;bottom:18px;width:42px;height:42px;border-radius:50%;border:1.5px solid #1b3def;background:rgba(255,255,255,.45);color:#1b3def;font-size:24px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;transition:background .2s,color .2s,transform .2s;}\n.bx-ex__open:hover{background:#1b3def;color:#fff;transform:scale(1.06);}\n@media(max-width:380px){.bx-ex__card{flex-direction:column;}.bx-ex__photo{flex:none;max-width:100%;aspect-ratio:16/10;}}\n/* modal */\n.bx-modal{position:fixed;inset:0;z-index:99999;display:none;align-items:center;justify-content:center;padding:20px;}\n.bx-modal.is-open{display:flex;}\n.bx-modal__overlay{position:absolute;inset:0;background:rgba(19,28,90,.55);backdrop-filter:blur(3px);}\n.bx-modal__box{position:relative;z-index:1;background:#fff;border-radius:22px;max-width:480px;width:100%;max-height:88vh;overflow-y:auto;padding:28px 28px 32px;box-shadow:0 30px 70px rgba(19,28,90,.3);}\n.bx-modal__close{position:absolute;top:14px;right:16px;width:36px;height:36px;border:none;background:transparent;font-size:28px;line-height:1;color:#1b3def;cursor:pointer;padding:0;}\n.bx-modal__photo{width:100%;aspect-ratio:4/3;border-radius:14px;overflow:hidden;background:linear-gradient(135deg,#eef1fc,#dce4f8);margin-bottom:20px;}\n.bx-modal__photo img{width:100%;height:100%;object-fit:cover;display:block;}\n.bx-modal__name{margin:0 0 4px;font-size:26px;font-weight:700;color:#1b3def;line-height:1.15;}\n.bx-modal__role{margin:0 0 18px;font-size:15px;font-weight:700;color:#1b3def;}\n.bx-modal__bio{border-left:3px solid #1b3def;padding-left:18px;font-size:15px;line-height:1.65;color:#2c2d2e;}\n.bx-modal__bio p{margin:0 0 12px;}.bx-modal__bio p:last-child{margin:0;}\n</style>\n<script>\n(function(){\n  function closeAll(){document.querySelectorAll('.bx-modal.is-open').forEach(function(m){m.classList.remove('is-open');});document.body.style.overflow='';}\n  document.querySelectorAll('[data-bx-open]').forEach(function(btn){btn.addEventListener('click',function(){var m=document.getElementById('bx-modal-'+btn.getAttribute('data-bx-open'));if(m){closeAll();m.classList.add('is-open');document.body.style.overflow='hidden';}});});\n  document.querySelectorAll('.bx-modal').forEach(function(m){m.addEventListener('click',function(e){if(e.target===m||e.target.classList.contains('bx-modal__overlay'))closeAll();});});\n  document.querySelectorAll('.bx-modal__close').forEach(function(b){b.addEventListener('click',closeAll);});\n  document.addEventListener('keydown',function(e){if(e.key==='Escape')closeAll();});\n})();\n</script>"
