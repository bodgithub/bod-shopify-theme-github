    "bod_hero": {
      "type": "custom-liquid",
      "name": "Hero",
      "settings": {
        "custom_liquid": "<style>\n/* ===== Bodology experts page — design system ===== */\n.bx{padding:clamp(56px,8vw,100px) 0;}\n.bx--soft{background:#f6f7fb;}\n.bx__container{max-width:1120px;margin:0 auto;padding:0 24px;}\n.bx__container--narrow{max-width:860px;}\n.bx__head{text-align:center;max-width:720px;margin:0 auto clamp(36px,5vw,56px);}\n.bx__eyebrow{margin:0 0 14px;font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#1b3def;}\n.bx__title{margin:0 0 16px;font-size:clamp(28px,4vw,42px);line-height:1.12;color:#1b3def;font-weight:700;}\n.bx__title em{font-style:italic;}\n.bx__lead{margin:0;font-size:clamp(16px,1.6vw,18px);line-height:1.6;color:#2c2d2e;opacity:.82;}\n/* hero */\n.bx--hero{background:radial-gradient(125% 145% at 15% 10%,#3a55ff 0%,#1b3def 48%,#132cb8 100%);color:#fff;padding:clamp(76px,12vw,148px) 0;}\n.bx-hero__inner{text-align:center;max-width:820px;margin:0 auto;}\n.bx-hero__eyebrow{margin:0 0 16px;font-size:12px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.78);}\n.bx-hero__title{margin:0 0 20px;font-size:clamp(34px,6vw,58px);line-height:1.06;font-weight:700;color:#fff;}\n.bx-hero__title em{font-style:italic;}\n.bx-hero__lead{margin:0 auto 34px;max-width:580px;font-size:clamp(16px,1.8vw,19px);line-height:1.6;color:#fff;opacity:.92;}\n.bx-hero__actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}\n/* buttons */\n.bx-btn{display:inline-block;padding:15px 36px;border-radius:999px;font-weight:700;font-size:15px;text-decoration:none;transition:transform .25s ease,background .25s ease,border-color .25s ease;}\n.bx-btn--light{background:#fff;color:#1b3def;}\n.bx-btn--light:hover{transform:translateY(-2px);background:#f3eeeb;}\n.bx-btn--ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.55);}\n.bx-btn--ghost:hover{transform:translateY(-2px);border-color:#fff;}\n/* pillars */\n.bx-pillars{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}\n@media(max-width:900px){.bx-pillars{grid-template-columns:repeat(2,1fr);}}\n@media(max-width:540px){.bx-pillars{grid-template-columns:1fr;}}\n.bx-pillar{background:#fff;border:1px solid #e6e9f5;border-radius:18px;padding:28px 24px;}\n.bx-pillar__n{font-size:13px;font-weight:700;color:#1b3def;letter-spacing:.05em;}\n.bx-pillar__t{margin:12px 0 10px;font-size:15px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#1b3def;}\n.bx-pillar__d{margin:0;font-size:14.5px;line-height:1.6;color:#2c2d2e;opacity:.85;}\n/* experts grid */\n.bx-experts{display:grid;grid-template-columns:repeat(4,1fr);gap:26px;}\n@media(max-width:1024px){.bx-experts{grid-template-columns:repeat(2,1fr);}}\n@media(max-width:560px){.bx-experts{grid-template-columns:1fr;}}\n.bx-card{background:#fff;border:1px solid #e6e9f5;border-radius:22px;overflow:hidden;display:flex;flex-direction:column;transition:transform .35s ease,box-shadow .35s ease;}\n.bx-card:hover{transform:translateY(-6px);box-shadow:0 20px 46px rgba(27,61,239,.13);}\n.bx-card__media{aspect-ratio:4/5;background:#eef0fb;overflow:hidden;}\n.bx-card__img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .55s ease;}\n.bx-card:hover .bx-card__img{transform:scale(1.05);}\n.bx-card__ph{width:100%;height:100%;background:linear-gradient(135deg,#eef0fb,#dfe4f8);}\n.bx-card__body{padding:22px 22px 24px;display:flex;flex-direction:column;gap:6px;flex:1;}\n.bx-card__name{margin:0;font-size:19px;font-weight:700;color:#1b3def;line-height:1.2;}\n.bx-card__role{margin:0;font-size:13.5px;line-height:1.45;color:#2c2d2e;opacity:.72;}\n.bx-card__bio{margin-top:auto;border-top:1px solid #eef0f8;padding-top:14px;}\n.bx-card__bio summary{cursor:pointer;list-style:none;font-size:11.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#1b3def;display:flex;align-items:center;}\n.bx-card__bio summary::-webkit-details-marker{display:none;}\n.bx-card__bio summary::after{content:\"+\";margin-left:auto;font-size:18px;line-height:1;color:#1b3def;transition:transform .3s ease;}\n.bx-card__bio[open] summary::after{transform:rotate(45deg);}\n.bx-card__bioc{margin-top:12px;font-size:13.5px;line-height:1.6;color:#2c2d2e;}\n.bx-card__bioc p{margin:0 0 10px;}.bx-card__bioc p:last-child{margin:0;}\n/* accordion */\n.bx-acc{display:flex;flex-direction:column;gap:12px;}\n.bx-acc__item{background:#fff;border:1px solid #e6e9f5;border-radius:16px;padding:4px 24px;}\n.bx-acc__item summary{cursor:pointer;list-style:none;display:flex;align-items:center;padding:20px 0;font-size:16px;font-weight:700;color:#1b3def;}\n.bx-acc__item summary::-webkit-details-marker{display:none;}\n.bx-acc__item summary::after{content:\"+\";margin-left:auto;padding-left:16px;font-size:22px;line-height:1;color:#1b3def;transition:transform .3s ease;}\n.bx-acc__item[open] summary::after{transform:rotate(45deg);}\n.bx-acc__c{padding:0 0 22px;font-size:15px;line-height:1.65;color:#2c2d2e;opacity:.88;}\n.bx-acc__c p{margin:0;}\n/* cta */\n.bx-cta{background:radial-gradient(125% 165% at 82% 0%,#3a55ff 0%,#1b3def 55%,#132cb8 100%);border-radius:28px;padding:clamp(48px,7vw,84px) 28px;text-align:center;color:#fff;}\n.bx-cta__eyebrow{margin:0 0 14px;font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.78);}\n.bx-cta__title{margin:0 0 14px;font-size:clamp(26px,3.5vw,38px);line-height:1.12;color:#fff;}\n.bx-cta__text{margin:0 auto 30px;max-width:520px;font-size:16px;line-height:1.6;color:#fff;opacity:.9;}\n.bx-cta__btn{display:inline-block;background:#fff;color:#1b3def;font-weight:700;padding:16px 42px;border-radius:999px;text-decoration:none;transition:transform .25s ease,background .25s ease;}\n.bx-cta__btn:hover{transform:translateY(-2px);background:#f3eeeb;}\n</style>\n<section class=\"bx bx--hero\">\n  <div class=\"bx__container\">\n    <div class=\"bx-hero__inner\">\n      <p class=\"bx-hero__eyebrow\">The experts behind Bodology</p>\n      <h1 class=\"bx-hero__title\">Backed by <em>science</em>.<br>Guided by <em>experts</em>.</h1>\n      <p class=\"bx-hero__lead\">Your metabolism powers everything — hormones, mood, fertility. Every scoop of Bodology is shaped by the experts who understand how it all connects.</p>\n      <div class=\"bx-hero__actions\">\n        <a class=\"bx-btn bx-btn--light\" href=\"#experts\">Meet the team</a>\n        <a class=\"bx-btn bx-btn--ghost\" href=\"/products/myo-d-chiro-inositol-powder\">Shop inositol</a>\n      </div>\n    </div>\n  </div>\n</section>"
      }
    },
    "bod_ethos": {
      "type": "custom-liquid",
      "name": "Ethos",
      "settings": {
        "custom_liquid": "<section class=\"bx bx--soft\">\n  <div class=\"bx__container\">\n    <header class=\"bx__head\">\n      <p class=\"bx__eyebrow\">Why it matters</p>\n      <h2 class=\"bx__title\">Not made to sell. <em>Made to work.</em></h2>\n      <p class=\"bx__lead\">We’re not here to sell trends. We’re here to fix what’s broken — in women’s healthcare, in the supplement aisle, and in the stories you’ve been told about your body. So we built Bodology with the people who study it for a living.</p>\n    </header>\n    <div class=\"bx-pillars\">\n      <div class=\"bx-pillar\"><span class=\"bx-pillar__n\">01</span><h3 class=\"bx-pillar__t\">Rooted in research</h3><p class=\"bx-pillar__d\">Only clinically-proven ingredients at therapeutic doses. Our 40:1 Myo &amp; D-Chiro Inositol mirrors what your body needs — no fluff, no fillers.</p></div>\n      <div class=\"bx-pillar\"><span class=\"bx-pillar__n\">02</span><h3 class=\"bx-pillar__t\">Validated by experts</h3><p class=\"bx-pillar__d\">We work with respected health professionals so every claim is backed by clinical data — not wellness marketing.</p></div>\n      <div class=\"bx-pillar\"><span class=\"bx-pillar__n\">03</span><h3 class=\"bx-pillar__t\">Transparent by design</h3><p class=\"bx-pillar__d\">We share our Certificates of Analysis, testing, and the reason behind every ingredient. You deserve to know exactly what’s in your body — and why it works.</p></div>\n      <div class=\"bx-pillar\"><span class=\"bx-pillar__n\">04</span><h3 class=\"bx-pillar__t\">Pioneering the future</h3><p class=\"bx-pillar__d\">We review and contribute to the latest science to redefine what hormone support really means — for PCOS, fertility, mood, and more.</p></div>\n    </div>\n  </div>\n</section>"
      }
    },
    "bod_experts": {
      "type": "custom-liquid",
      "name": "Experts",
      "settings": {
        "custom_liquid": "<section id=\"experts\" class=\"bx\">\n  <div class=\"bx__container\">\n    <header class=\"bx__head\">\n      <p class=\"bx__eyebrow\">Meet the team</p>\n      <h2 class=\"bx__title\">Our <em>scientific advisory</em> board</h2>\n      <p class=\"bx__lead\">Trusted voices in metabolic health, hormone research, and functional medicine — the people who guide what we make and stand behind it.</p>\n    </header>\n    <div class=\"bx-experts\">\n      <article class=\"bx-card\">\n        {%- assign e = metaobjects.experts[\"a-tina-kozman\"] -%}\n        <div class=\"bx-card__media\">\n          {%- if e.expert_photo.value != blank -%}\n            {{ e.expert_photo.value | image_url: width: 720 | image_tag: loading: 'lazy', class: 'bx-card__img', alt: e.expert_name.value }}\n          {%- else -%}<div class=\"bx-card__ph\"></div>{%- endif -%}\n        </div>\n        <div class=\"bx-card__body\">\n          <h3 class=\"bx-card__name\">{{ e.expert_name.value }}</h3>\n          <p class=\"bx-card__role\">{{ e.expert_title.value }}</p>\n          {%- if e.bio != blank -%}\n          <details class=\"bx-card__bio\"><summary>Read bio</summary>\n            <div class=\"bx-card__bioc\">{{ e.bio | metafield_tag }}</div>\n          </details>\n          {%- endif -%}\n        </div>\n      </article>\n      <article class=\"bx-card\">\n        {%- assign e = metaobjects.experts[\"c-dr-anita\"] -%}\n        <div class=\"bx-card__media\">\n          {%- if e.expert_photo.value != blank -%}\n            {{ e.expert_photo.value | image_url: width: 720 | image_tag: loading: 'lazy', class: 'bx-card__img', alt: e.expert_name.value }}\n          {%- else -%}<div class=\"bx-card__ph\"></div>{%- endif -%}\n        </div>\n        <div class=\"bx-card__body\">\n          <h3 class=\"bx-card__name\">{{ e.expert_name.value }}</h3>\n          <p class=\"bx-card__role\">{{ e.expert_title.value }}</p>\n          {%- if e.bio != blank -%}\n          <details class=\"bx-card__bio\"><summary>Read bio</summary>\n            <div class=\"bx-card__bioc\">{{ e.bio | metafield_tag }}</div>\n          </details>\n          {%- endif -%}\n        </div>\n      </article>\n      <article class=\"bx-card\">\n        {%- assign e = metaobjects.experts[\"leslie-kutcha-fdnp\"] -%}\n        <div class=\"bx-card__media\">\n          {%- if e.expert_photo.value != blank -%}\n            {{ e.expert_photo.value | image_url: width: 720 | image_tag: loading: 'lazy', class: 'bx-card__img', alt: e.expert_name.value }}\n          {%- else -%}<div class=\"bx-card__ph\"></div>{%- endif -%}\n        </div>\n        <div class=\"bx-card__body\">\n          <h3 class=\"bx-card__name\">{{ e.expert_name.value }}</h3>\n          <p class=\"bx-card__role\">{{ e.expert_title.value }}</p>\n          {%- if e.bio != blank -%}\n          <details class=\"bx-card__bio\"><summary>Read bio</summary>\n            <div class=\"bx-card__bioc\">{{ e.bio | metafield_tag }}</div>\n          </details>\n          {%- endif -%}\n        </div>\n      </article>\n      <article class=\"bx-card\">\n        {%- assign e = metaobjects.experts[\"a-hillary-rd\"] -%}\n        <div class=\"bx-card__media\">\n          {%- if e.expert_photo.value != blank -%}\n            {{ e.expert_photo.value | image_url: width: 720 | image_tag: loading: 'lazy', class: 'bx-card__img', alt: e.expert_name.value }}\n          {%- else -%}<div class=\"bx-card__ph\"></div>{%- endif -%}\n        </div>\n        <div class=\"bx-card__body\">\n          <h3 class=\"bx-card__name\">{{ e.expert_name.value }}</h3>\n          <p class=\"bx-card__role\">{{ e.expert_title.value }}</p>\n          {%- if e.bio != blank -%}\n          <details class=\"bx-card__bio\"><summary>Read bio</summary>\n            <div class=\"bx-card__bioc\">{{ e.bio | metafield_tag }}</div>\n          </details>\n          {%- endif -%}\n        </div>\n      </article>\n    </div>\n  </div>\n</section>"
      }
