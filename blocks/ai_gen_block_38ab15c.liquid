      "default": 20
    },
    {
      "type": "range",
      "id": "number_padding",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Number padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "number_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Number border radius",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Countdown banner"
    }
  ]
