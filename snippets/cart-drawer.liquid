
{%- if settings.cart_drawer -%}
{%- liquid
	assign free_shipping = settings.free_shipping
	assign free_shipping_minimum = settings.free_shipping_minimum | times: 100
	assign total = cart.total_price
	assign shadow_class = 'has-shadow--' | append: settings.block_shadows
-%}
{%- comment -%} Bodology cart drawer styling {%- endcomment -%}
<style>
#Cart-Drawer{--bod-blue:#1b3def;--bod-ink:#1a1a14;--bod-muted:#6a6e7a;--bod-line:rgba(20,40,120,0.12);--bod-sand:#f7f5f1;--bod-grad:linear-gradient(110deg,#0e2160 0%,#1b3def 62%,#0a95ef 130%);color:var(--bod-ink);}
#Cart-Drawer *{box-sizing:border-box;}
#Cart-Drawer .side-panel-header{padding:12px 22px 8px;}
#Cart-Drawer .side-panel-header > div{display:flex;align-items:center;justify-content:space-between;gap:12px;border-bottom:0 !important;padding:5px !important;}
#Cart-Drawer .side-panel-header .h6{font-size:14px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--bod-ink);margin:0;}
#Cart-Drawer .side-panel-header .h6 sup{font-size:10px;font-weight:700;color:var(--bod-blue);top:-0.5em;margin-left:2px;}
#Cart-Drawer .side-panel-close{cursor:pointer;color:var(--bod-ink);opacity:.65;display:flex;}
#Cart-Drawer .side-panel-close:hover{opacity:1;}
#Cart-Drawer .side-panel-close svg{width:15px;height:15px;}
#Cart-Drawer .side-panel-content{padding:0;}
#Cart-Drawer .free-shipping{display:flex;flex-direction:column-reverse;gap:8px;padding:6px 22px 16px;margin:0;}
#Cart-Drawer .free-shipping--bar{height:9px;border-radius:999px;background:var(--bod-line);overflow:hidden;}
#Cart-Drawer .free-shipping--percentage{background:var(--bod-grad);border-radius:999px;}
#Cart-Drawer .free-shipping--text{text-align:center;font-size:12.5px;font-weight:600;color:var(--bod-ink);line-height:1.3;}
#Cart-Drawer .free-shipping--text-full{color:var(--bod-blue);}
#Cart-Drawer .product-cart-item--container{padding:0;display:flex;flex-direction:column;}
#Cart-Drawer .product-cart-item--container > .free-shipping{order:0;}
#Cart-Drawer .product-cart-item{order:1;}
#Cart-Drawer .product-cart-item.is-gift{order:2;}
#Cart-Drawer .product-cart-item .quantity,#Cart-Drawer .product-cart-item quantity-selector{display:none !important;}
#Cart-Drawer .product-cart-item{position:relative;display:grid;grid-template-columns:72px minmax(0,1fr) auto;grid-template-areas:"img info price" "upg upg upg";column-gap:14px;align-items:start;padding:18px 22px;margin:0;border-bottom:1px solid var(--bod-line);border-top:0;}
#Cart-Drawer .product-cart-item-image{grid-area:img;width:72px;height:72px;}
#Cart-Drawer .product-cart-item-image img{width:72px;height:72px;object-fit:cover;border-radius:12px;background:var(--bod-sand);}
#Cart-Drawer .product-cart-item-info{grid-area:info;display:flex;flex-direction:column;gap:6px;min-width:0;padding:0;}
#Cart-Drawer .cart-product-link{font-size:14.5px;font-weight:700;line-height:1.22;color:var(--bod-ink);text-decoration:none;padding-right:24px;}
#Cart-Drawer .product-cart-item-info > .price{display:none;}
#Cart-Drawer .selling-plan,#Cart-Drawer .product-cart-item-options{font-size:12.5px;color:var(--bod-muted);line-height:1.3;margin:0;}
#Cart-Drawer .properties{margin:0;}
#Cart-Drawer .quantity.cart-update{position:relative;display:inline-flex !important;align-items:center;justify-content:flex-start;gap:0;border:0;border-radius:999px;padding:2px;width:auto;max-width:none;height:34px;margin-top:3px;background:#fff;}
#Cart-Drawer .quantity.cart-update button{position:static !important;inset:auto !important;transform:none !important;flex:0 0 28px;width:28px !important;height:28px !important;min-width:28px;border:0;background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--bod-ink);border-radius:50%;padding:0;margin:0;}
#Cart-Drawer .quantity.cart-update button:hover{background:var(--bod-sand);}
#Cart-Drawer .quantity.cart-update button svg{width:11px;height:11px;}
#Cart-Drawer .quantity.cart-update input{position:static !important;inset:auto !important;flex:0 0 34px;width:34px !important;min-width:34px;height:auto !important;border:0;text-align:center;font-size:14px;font-weight:600;background:transparent;padding:0;margin:0;-moz-appearance:textfield;}
#Cart-Drawer .quantity.cart-update input::-webkit-outer-spin-button,#Cart-Drawer .quantity.cart-update input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0;}
#Cart-Drawer .product-cart-item-price{grid-area:price;align-self:end;text-align:right;padding:0;}
#Cart-Drawer .product-cart-item-price .price{display:flex;flex-direction:row;align-items:baseline;gap:6px;justify-content:flex-end;}
#Cart-Drawer .product-cart-item-price del{order:2;font-size:13px;color:#9aa0b5;text-decoration:line-through;}
#Cart-Drawer .product-cart-item-price ins{order:1;text-decoration:none;font-size:15px;font-weight:700;color:var(--bod-ink);}
#Cart-Drawer .product-cart-item-price ins.is-free{color:var(--bod-blue);text-transform:uppercase;letter-spacing:0.02em;}
#Cart-Drawer .product-cart-item-price .unit-price{display:none;}
#Cart-Drawer .product-cart-item .remove{position:absolute;top:16px;right:20px;color:var(--bod-muted);opacity:.55;width:18px;height:18px;display:flex;align-items:center;justify-content:center;}
#Cart-Drawer .product-cart-item .remove:hover{opacity:1;color:var(--bod-blue);}
#Cart-Drawer .product-cart-item .remove svg{width:15px;height:15px;}
#Cart-Drawer .bod-upgrade{grid-area:upg;margin:12px 0 0;width:100%;border:0;cursor:pointer;border-radius:10px;padding:11px 14px;font-size:13px;font-weight:700;color:#fff;background:var(--bod-grad);display:flex;align-items:center;justify-content:center;gap:8px;line-height:1;transition:filter .15s,transform .12s;box-shadow:0 6px 16px rgba(27,61,239,0.22);}
#Cart-Drawer .bod-upgrade:hover{filter:brightness(1.08);}
#Cart-Drawer .bod-upgrade:active{transform:translateY(1px);}
#Cart-Drawer .bod-upgrade.is-loading{opacity:.55;pointer-events:none;}
#Cart-Drawer .bod-upgrade svg{width:14px;height:14px;flex:0 0 auto;}
#Cart-Drawer .side-panel-footer{padding:0;border-top:1px solid var(--bod-line);}
#Cart-Drawer .cart-drawer-footer{padding:18px 22px 20px;}
#Cart-Drawer .collaterals{width:100%;margin:0 0 14px;border:0;}
#Cart-Drawer .collaterals th,#Cart-Drawer .collaterals td{border:0;padding:2px 0;}
#Cart-Drawer .cart-total th{font-size:15px;font-weight:700;text-align:left;color:var(--bod-ink);vertical-align:top;}
#Cart-Drawer .cart-total td{text-align:right;font-size:18px;font-weight:700;color:var(--bod-ink);vertical-align:top;}
#Cart-Drawer .cart-policy-text{font-size:11px;font-weight:400;color:var(--bod-muted);margin:3px 0 0;}
#Cart-Drawer .cart-discount th{font-size:13px;font-weight:600;color:var(--bod-blue);text-align:left;}
#Cart-Drawer .cart-discount td{font-size:13px;color:var(--bod-blue);text-align:right;}
#Cart-Drawer .cart-drawer-buttons{display:flex;flex-direction:column;gap:10px;margin:0;}
#Cart-Drawer .cart-drawer-buttons form{margin:0;width:100%;}
#Cart-Drawer .cart-drawer-buttons .button{width:100%;border-radius:12px !important;padding:16px 22px !important;font-size:16px !important;font-weight:700 !important;letter-spacing:0;text-transform:none;border:0 !important;}
#Cart-Drawer .cart-drawer-buttons .button.checkout,#Cart-Drawer .cart-drawer-buttons .button.accent{background:var(--bod-grad) !important;color:#fff !important;box-shadow:0 10px 26px rgba(27,61,239,0.26);}
#Cart-Drawer .cart-drawer-buttons .button.checkout:hover{filter:brightness(1.06);}
#Cart-Drawer .cart-drawer-buttons .button:not(.checkout):not(.accent){background:#fff !important;color:var(--bod-blue) !important;border:1px solid var(--bod-line) !important;}
#Cart-Drawer .cart-drawer__empty-cart .button.accent2{background:var(--bod-grad) !important;color:#fff !important;border-radius:12px !important;}
#Cart-Drawer .bod-discount{display:flex;gap:8px;width:100%;margin:0;}
#Cart-Drawer .bod-discount input{flex:1 1 auto;min-width:0;border:1px solid var(--bod-line);border-radius:10px;padding:12px 14px;font-size:14px;color:var(--bod-ink);background:#fff;}
#Cart-Drawer .bod-discount input:focus{outline:none;border-color:var(--bod-blue);}
#Cart-Drawer .bod-discount button{flex:0 0 auto;border:0;cursor:pointer;border-radius:10px;padding:0 18px;font-size:14px;font-weight:700;color:var(--bod-blue);background:var(--bod-sand);}
#Cart-Drawer .bod-discount button:hover{background:#edf0fb;}
#Cart-Drawer .bod-discount.is-loading{opacity:.6;pointer-events:none;}
#Cart-Drawer .bod-discount-msg{font-size:12px;color:#b42318;margin:6px 0 2px;}
#Cart-Drawer .discounts:empty{display:none;}
</style>
<div class="side-panel cart-drawer {{ shadow_class }}" id="Cart-Drawer" tabindex="-1">
	<div class="side-panel-inner">
		<div class="side-panel-header">
			<div>
				<span class="h6">Your cart</span>
				<side-panel-close class="side-panel-close">{%- render 'svg-icons' with 'close' -%}</side-panel-close>
			</div>
		</div>
		<div class="side-panel-content">
			{%- if cart != empty -%}
				<div class="product-cart-item--container">
					{%- liquid
						if free_shipping and settings.free_shipping_minimum != blank
							render 'free-shipping', free_shipping_minimum: free_shipping_minimum, total: total
						endif
					-%}
					{% for item in cart.items %}
					<div class="product-cart-item{% if item.properties['_gift'] %} is-gift{% endif %}{% if item.selling_plan_allocation %} no-qty{% endif %}" id="CartDrawerItem-{{ item.index | plus: 1 }}">
						<div class="product-cart-item-image">
							{% if item.image %}
								{%- render 'responsive-image', image: item.image, sizes: '168x0', priority: 'low' -%}
							{% else %}
								<div class="thb-placeholder" style="width: 100px;">
									{{ 'product-1' | placeholder_svg_tag }}
								</div>
							{% endif %}
							<div class="loading-overlay">
								{% render 'svg-icons' with 'thb-loading' %}
							</div>
						</div>
						<div class="product-cart-item-info">
							<a href="{{ item.url }}" title="{{ item.product.title | escape }}" class="cart-product-link">{%- if item.selling_plan_allocation -%}{{ item.selling_plan_allocation.selling_plan.name }}{%- else -%}{{ item.product.title }}{%- endif -%}</a>
							<span class="price">
								{%- if item.final_line_price == 0 -%}{%- assign strike = 0 -%}{%- if item.original_line_price > 0 -%}{%- assign strike = item.original_line_price -%}{%- elsif item.variant.compare_at_price > item.variant.price -%}{%- assign strike = item.variant.compare_at_price | times: item.quantity -%}{%- endif -%}{%- if strike > 0 -%}<del><span class="amount">{{ strike | money }}</span></del>{%- endif -%}<ins class="is-free"><span class="amount">Free</span></ins>{%- elsif item.original_line_price != item.final_line_price -%}<del><span class="amount">{{ item.original_line_price | money }}</span></del><ins><span class="amount">{{ item.final_line_price | money }}</span></ins>{%- else -%}<ins><span class="amount">{{ item.original_line_price | money }}</span></ins>{%- endif -%}
								{%- if item.variant.available and item.unit_price_measurement -%}
									<small class="unit-price">
										{{ item.variant.unit_price | money }}
										<span class="unit-price-separator">/</span>
										{%- if item.variant.unit_price_measurement.reference_value != 1 -%}
										{{- item.variant.unit_price_measurement.reference_value -}}
										{%- endif -%}
										{{ item.variant.unit_price_measurement.reference_unit }}
									</small>
								{%- endif -%}
							</span>





                
							{% if item.selling_plan_allocation %}
							<div class="properties">
								<span class="selling-plan">{{ item.product.title }}</span>
							</div>
							{% endif %}
							{% unless item.variant.title contains 'Default' or item.selling_plan_allocation %}
								<div class="product-cart-item-options">
									{% for option in item.product.options %}
										{{ item.variant.options[forloop.index0] }}{% if forloop.last != true %}, {% endif %}
									{% endfor %}
								</div>
							{% endunless %}
							{%- for property in item.properties -%}
								{%- assign property_first_char = property.first | slice: 0 -%}
								{%- if property.last != blank and property_first_char != '_' -%}
									<div class="product-cart-item-options">
										<span>{{ property.first }}: </span>
											{%- if property.last contains '/uploads/' -%}
												<a href="{{ property.last }}" class="link" target="_blank">
													{{ property.last | split: '/' | last }}
												</a>
											{%- else -%}
												{{ property.last }}
											{%- endif -%}
											<br/>
									</div>
								{%- endif -%}
							{%- endfor -%}
							{%- if item.discounts != blank -%}
							<ul class="discounts" role="list">
								{%- for discount in item.discounts -%}
									{%- if discount.amount > 0 -%}
									<li class="discounts__discount">
										{%- render 'svg-icons' with 'discount' -%}
										{{ discount.title }} (-{{ discount.amount | money }})
									</li>
									{%- endif -%}
								{%- endfor -%}
							</ul>
							{%- endif -%}
							<quantity-selector class="quantity cart-update small-qty" data-id="{{ item.key | escape }}">
							 <button class="minus" type="button" aria-label="{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}">{% render 'svg-icons' with 'minus' %}</button>
							 <input
							 type="number"
							 name="updates[]"
							 id="updates_{{ item.key }}"
							 value="{{ item.quantity }}"
							 min="{{ item.variant.quantity_rule.min }}"
							 {% if item.variant.quantity_rule.max != null %}
		           max="{{ item.variant.quantity_rule.max }}"
							 {% elsif item.variant.inventory_management != null and item.variant.inventory_quantity > 0 %}
							 max="{{ item.variant.inventory_quantity }}"
		           {% endif %}
							 step="{{ item.variant.quantity_rule.increment }}"
							 class="qty"
							 data-index="{{ item.index | plus: 1 }}"
							 aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
							 >
							 <button class="plus" type="button" aria-label="{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}">{% render 'svg-icons' with 'plus' %}</button>
							
                              
                            </quantity-selector>

                          

                      
							<a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&amp;quantity=0" class="remove" data-index="{{ item.index | plus: 1 }}">{% render 'svg-icons' with 'trash' %}</a>
						
               
                      </div>

                    
						{%- unless item.selling_plan_allocation -%}{%- assign upg_plan = '' -%}{%- if item.variant.id == 46444646269147 -%}{%- assign upg_plan = '5755961563' -%}{%- elsif item.variant.id == 46444657279195 -%}{%- assign upg_plan = '6331924699' -%}{%- endif -%}{%- if upg_plan != '' -%}<button type="button" class="bod-upgrade" data-line-key="{{ item.key | escape }}" data-plan="{{ upg_plan }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg><span>Save an Extra 15% Instantly</span></button>{%- endif -%}{%- endunless -%}
						<div class="product-cart-item-price">
							<span class="price">
							{%- if item.final_line_price == 0 -%}{%- assign strike = 0 -%}{%- if item.original_line_price > 0 -%}{%- assign strike = item.original_line_price -%}{%- elsif item.variant.compare_at_price > item.variant.price -%}{%- assign strike = item.variant.compare_at_price | times: item.quantity -%}{%- endif -%}{%- if strike > 0 -%}<del><span class="amount">{{ strike | money }}</span></del>{%- endif -%}<ins class="is-free"><span class="amount">Free</span></ins>{%- elsif item.original_line_price != item.final_line_price -%}<del><span class="amount">{{ item.original_line_price | money }}</span></del><ins><span class="amount">{{ item.final_line_price | money }}</span></ins>{%- else -%}<ins><span class="amount">{{ item.original_line_price | money }}</span></ins>{%- endif -%}
							{%- if item.variant.available and item.unit_price_measurement -%}
								<small class="unit-price">
									{{ item.variant.unit_price | money }}
									<span class="unit-price-separator">/</span>
									{%- if item.variant.unit_price_measurement.reference_value != 1 -%}
									{{- item.variant.unit_price_measurement.reference_value -}}
									{%- endif -%}
									{{ item.variant.unit_price_measurement.reference_unit }}
								</small>
                              
							{%- endif -%}
							</span>
                           
                      
						</div>
					</div>
                  
					{% endfor %}

              
                                    

              

				</div>
			{%- else -%}
				<div class="cart-drawer__empty-cart">
					{% render 'svg-icons' with 'thb-empty-cart' %}
					<p>{{ 'general.cart_drawer.cart_empty' | t }}</p>
					<a class="button accent2" href="{{ routes.all_products_collection_url }}"><span>{{ 'general.cart_drawer.start_shopping' | t }}</span></a>
				</div>
			{%- endif -%}
			{%- if settings.cart_recommendations and cart != empty -%}
			<product-recommendations class="complementary-products" data-url="{{ routes.product_recommendations_url }}?section_id=cart-drawer&product_id={{ cart.items[0].product_id }}&limit=4">
			  {% if recommendations.performed and recommendations.products_count > 0 %}
					<div class="complementary-products--heading">{{ 'general.cart_drawer.you_may_also_like' | t }}</div>
					<scroll-shadow>
				    <div class="complementary-products--inner">
				      {% for recommendation in recommendations.products %}
				        {% render 'product-card-small' product_small: recommendation %}
				      {% endfor %}
				    </div>
					</scroll-shadow>
			  {% endif %}
			</product-recommendations>
			{%- endif -%}
		</div>
		{%- if cart != empty -%}
			<div class="side-panel-footer">
				<div class="cart-drawer-footer">
					<table class="collaterals">
						<tbody>
							{%- if cart.cart_level_discount_applications.size > 0 -%}
								{%- for discount in cart.cart_level_discount_applications -%}
									<tr class="cart-discount">
										<th>{{ discount.title }}</th>
										<td>
											<span class="price">
												<span class="amount">
												{% if settings.currency_code_enabled %}
												-{{ discount.total_allocated_amount | money_with_currency }}
												{% else %}
												-{{ discount.total_allocated_amount | money }}
												{% endif %}
											 </span>
											</span>
										</td>
									</tr>
								{%- endfor -%}
							{%- endif -%}
							<tr class="cart-total">
 								<th>
									Subtotal
								</th>
								<td>
									<span class="price">
										<span class="amount">
										 {% if settings.currency_code_enabled %}
											{{ cart.total_price | money_with_currency }}
										 {% else %}
											{{ cart.total_price | money }}
										 {% endif %}
									 </span>
								 </span>
								</td>
							</tr>
						</tbody>
					</table>
					{%- if settings.cart_drawer_notes -%}
					<button type="button" class="order-note-toggle" id="order-note-toggle" aria-controls="mini-cart-note">{{ 'general.cart_drawer.add_order_note' | t }}</button>
					<div class="order-note-toggle__content" id="mini-cart-note">
						<label for="mini-cart__notes">{{ 'general.cart_drawer.add_order_note' | t }}</label>
						<textarea name="note" id="mini-cart__notes" rows="5">{{ cart.note }}</textarea>
						<button class="button full"><span>{{ 'general.cart_drawer.save' | t }}</span></button>
						<div class="order-note-toggle__content-overlay"></div>
					</div>
					{%- endif -%}
					{% if settings.cart_terms_conditions_enable %}
            <div class="cart-drawer-terms">
              <input type="checkbox" id="CartDrawerTerms" required>
              <label for="CartDrawerTerms">
                {% if settings.cart_terms_conditions_page != blank %}
                  {{ 'sections.cart.terms_html' | t: url: settings.cart_terms_conditions_page.url }}
                {% else %}
                  {{ 'sections.cart.terms' | t }}
                {% endif %}
              </label>
            </div>
          {% endif %}
					<div class="cart-drawer-buttons">
						<form class="bod-discount" data-bod-discount novalidate>
							<input type="text" name="discount" placeholder="Discount code" autocomplete="off" spellcheck="false">
							<button type="submit">Apply</button>
						</form>
						<div class="bod-discount-msg" style="display:none;"></div>
						{%- if settings.cart_drawer_checkout_button -%}
						<form action="{{ routes.cart_url }}" method="post" novalidate>
							<button type="submit" class="button accent checkout full" name="checkout" title="{{ 'general.cart_drawer.checkout' | t | escape }}"><span>{{ 'general.cart_drawer.checkout' | t }}</span></button>
						</form>
						{%- endif -%}
					</div>
				</div>
			</div>
		{%- endif -%}
	</div>
</div>

{%- comment -%} Bodology cart drawer: subscription upgrade {%- endcomment -%}
<script>
(function(){
  if(window.__bodCartDrawerBound) return; window.__bodCartDrawerBound = true;
  function root(){ return (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/'; }
  function repl(sections, name, selector){
    if(!sections || !sections[name]) return;
    var frag = new DOMParser().parseFromString(sections[name], 'text/html').querySelector(selector);
    if(!frag) return;
    if(selector === '.cart-drawer'){ var host = document.getElementById('Cart-Drawer'); if(host) host.innerHTML = frag.innerHTML; }
    else { var tgt = document.querySelector(selector); if(tgt) tgt.innerHTML = frag.innerHTML; }
  }
  document.addEventListener('click', function(e){
    var btn = e.target.closest('.bod-upgrade'); if(!btn) return;
    e.preventDefault();
    if(btn.classList.contains('is-loading')) return;
    var key = btn.getAttribute('data-line-key'), plan = btn.getAttribute('data-plan');
    if(!key || !plan) return;
    btn.classList.add('is-loading');
    fetch(root()+'cart/change.js', { method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'},
      body: JSON.stringify({ id:key, selling_plan:plan, sections:['cart-drawer','cart-bubble'], sections_url: window.location.pathname }) })
    .then(function(r){ return r.json(); })
    .then(function(res){
      try {
        repl(res.sections, 'cart-drawer', '.cart-drawer');
        repl(res.sections, 'cart-bubble', '.thb-item-count');
        if(typeof CartDrawer !== 'undefined'){ new CartDrawer(); }
        document.dispatchEvent(new CustomEvent('cart:refresh'));
      } catch(err){}
    })
    .catch(function(){ btn.classList.remove('is-loading'); });
  });
  document.addEventListener('submit', function(e){
    var form = e.target.closest('[data-bod-discount]'); if(!form) return;
    e.preventDefault();
    var input = form.querySelector('input[name="discount"]'); var code = (input.value||'').trim(); if(!code) return;
    form.classList.add('is-loading');
    fetch(root()+'discount/'+encodeURIComponent(code)+'?redirect=/cart.js')
    .then(function(){ return fetch(root()+'cart.js'); })
    .then(function(r){ return r.json(); })
    .then(function(cart){
      var ok = (cart.cart_level_discount_applications && cart.cart_level_discount_applications.length) || cart.total_discount > 0;
      return fetch(root()+'?sections=cart-drawer,cart-bubble').then(function(r){ return r.json(); }).then(function(sections){
        repl(sections,'cart-drawer','.cart-drawer'); repl(sections,'cart-bubble','.thb-item-count');
        if(typeof CartDrawer !== 'undefined'){ new CartDrawer(); }
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        if(!ok){ var m=document.querySelector('#Cart-Drawer .bod-discount-msg'); if(m){ m.textContent='That code isn\u2019t valid.'; m.style.display='block'; } }
      });
    })
    .catch(function(){ form.classList.remove('is-loading'); });
  });
})();
</script>

{%- endif -%}
