{%- comment -%}
  Bodology · Experts (shared render)
  Rendered as a BLOCK inside the main-product (Product information) section,
  so it can be dropped onto product + product-landing templates from the editor.

  Params:
    s   - settings object (block.settings)
    uid - unique instance id (block.id)

  Up to 6 practitioners are exposed as flat settings (p1_..p6_) because a
  Shopify block cannot contain repeatable sub-blocks.
{%- endcomment -%}

{%- liquid
  assign bg = s.background
-%}

<style>
@import url("https://use.typekit.net/sxx4ssa.css");
@import url("https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap");

#exr-{{ uid }}{
  --sans:"tenon","Tenon Local","Helvetica Neue",Arial,sans-serif;
  --serif:"Instrument Serif","Times New Roman",Georgia,serif;
  --mono:"JetBrains Mono",ui-monospace,Menlo,monospace;
  --grad-solid:radial-gradient(140% 165% at 18% 10%,#2E54C8 0%,#1E3FA8 30%,#14307C 65%,#0E2160 100%);
  --accent:{{ s.accent_color | default: '#1B3DEF' }};
  --titlec:{{ s.title_color | default: '#14307C' }};
  --textc:{{ s.text_color | default: '#1A1A14' }};
  --pillc:{{ s.pill_color | default: '#1B3DEF' }};
  --muted:#6A6E7A; --hair:rgba(20,30,60,0.12);
  box-sizing:border-box; container-type:inline-size; font-family:var(--sans); color:var(--textc);
  max-width:{{ s.max_width | default: 640 }}px; margin:0 auto;
}
#exr-{{ uid }} *,#exr-{{ uid }} *::before,#exr-{{ uid }} *::after{box-sizing:border-box;}
{% if bg == 'gradient' %}#exr-{{ uid }}{background:var(--grad-solid); padding:26px 22px; border-radius:16px;}{% endif %}

#exr-{{ uid }} .exr__head{text-align:center; margin:0 auto 22px; max-width:46ch;}
#exr-{{ uid }} .exr__pill{display:inline-block; font-family:var(--mono); font-size:10px; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; padding:6px 14px; border-radius:999px; margin:0 0 14px; white-space:nowrap;
  {% if s.pill_style == 'outline' %}background:transparent; color:var(--pillc); border:1px solid var(--pillc);{% else %}background:var(--pillc); color:#fff; border:1px solid transparent;{% endif %}}
#exr-{{ uid }} .exr__title{font-family:{% if s.headline_style == 'serif' %}var(--serif); font-style:italic; font-weight:400{% else %}var(--sans); font-weight:600{% endif %}; font-size:clamp(21px,3vw,28px); letter-spacing:-0.03em; line-height:1.08; color:{% if bg == 'gradient' %}#fff{% else %}var(--titlec){% endif %}; margin:0 0 10px;}
#exr-{{ uid }} .exr__sub{font-size:14px; line-height:1.5; color:{% if bg == 'gradient' %}rgba(255,255,255,0.82){% else %}var(--muted){% endif %}; margin:0;}

#exr-{{ uid }} .exr__grid{display:flex; gap:14px; overflow-x:auto; scroll-snap-type:x proximity; padding:2px 2px 10px; scrollbar-width:thin; -webkit-overflow-scrolling:touch;}
#exr-{{ uid }} .exr__grid::-webkit-scrollbar{height:6px;}
#exr-{{ uid }} .exr__grid::-webkit-scrollbar-thumb{background:rgba(20,48,124,0.25); border-radius:999px;}
#exr-{{ uid }} .exr__card{flex:0 0 31%; min-width:178px; scroll-snap-align:start; border:1px solid var(--hair); border-radius:14px; overflow:hidden; background:#fff; cursor:pointer;}

#exr-{{ uid }} .exr__media{position:relative; aspect-ratio:1/1; background:#E9ECF6; overflow:hidden;}
#exr-{{ uid }} .exr__media img{width:100%; height:100%; object-fit:cover; display:block;}
#exr-{{ uid }} .exr__badge{position:absolute; top:9px; right:9px; width:22px; height:22px; border-radius:50%; background:rgba(255,255,255,0.85); color:var(--accent); display:flex; align-items:center; justify-content:center; font-family:var(--serif); font-style:italic; font-size:17px; line-height:0; padding-top:9px; transition:opacity .2s; box-shadow:0 2px 8px rgba(8,18,62,0.18);}

#exr-{{ uid }} .exr__quote{position:absolute; inset:0; padding:18px 16px; display:flex; flex-direction:column; justify-content:flex-end; gap:9px; background:linear-gradient(180deg, rgba(27,61,239,0.20) 0%, rgba(20,48,124,0.86) 50%, rgba(14,33,96,0.96) 100%); color:#fff; opacity:0; transition:opacity .22s ease;}
#exr-{{ uid }} .exr__qtext{font-family:var(--sans); font-weight:500; font-size:14.5px; line-height:1.4;}
#exr-{{ uid }} .exr__qby{font-family:var(--mono); font-size:9px; letter-spacing:0.08em; text-transform:uppercase; color:rgba(255,255,255,0.82);}
#exr-{{ uid }} .exr__card:hover .exr__quote,#exr-{{ uid }} .exr__card:focus-within .exr__quote,#exr-{{ uid }} .exr__card.is-open .exr__quote{opacity:1;}
#exr-{{ uid }} .exr__card:hover .exr__badge,#exr-{{ uid }} .exr__card.is-open .exr__badge{opacity:0;}

#exr-{{ uid }} .exr__body{padding:12px 14px 14px;}
#exr-{{ uid }} .exr__name{font-family:var(--sans); font-weight:600; font-size:14px; letter-spacing:-0.01em; color:var(--textc);}
#exr-{{ uid }} .exr__role{font-family:var(--mono); font-size:9.5px; letter-spacing:0.05em; text-transform:uppercase; color:var(--accent); margin-top:4px; line-height:1.4;}
#exr-{{ uid }} .exr__qm{display:none; font-family:var(--sans); font-weight:500; font-size:13.5px; line-height:1.42; color:var(--textc); margin:10px 0 0; padding-top:10px; border-top:1px solid var(--hair);}

@container (max-width:480px){
  #exr-{{ uid }} .exr__grid{display:block; overflow:visible; padding:0;}
  #exr-{{ uid }} .exr__card{display:grid; grid-template-columns:118px 1fr; margin-bottom:12px; min-width:0;}
  #exr-{{ uid }} .exr__media{aspect-ratio:auto; min-height:100%;}
  #exr-{{ uid }} .exr__quote,#exr-{{ uid }} .exr__badge{display:none;}
  #exr-{{ uid }} .exr__body{display:flex; flex-direction:column; justify-content:center; padding:14px;}
  #exr-{{ uid }} .exr__qm{display:block;}
}
</style>

<div id="exr-{{ uid }}" class="exr">
  <div class="exr__head">
    {% if s.pill_style != 'none' and s.pill_text != blank %}<span class="exr__pill">{{ s.pill_text }}</span>{% endif %}
    <h2 class="exr__title">{{ s.title | escape }}</h2>
    {% if s.subtitle != blank %}<p class="exr__sub">{{ s.subtitle | escape }}</p>{% endif %}
  </div>

  <div class="exr__grid">
    {%- for i in (1..6) -%}
      {%- liquid
        assign photo_key = 'p' | append: i | append: '_photo'
        assign name_key  = 'p' | append: i | append: '_name'
        assign role_key  = 'p' | append: i | append: '_role'
        assign quote_key = 'p' | append: i | append: '_quote'
      -%}
      {%- if s[name_key] != blank or s[photo_key] != blank -%}
        <div class="exr__card" tabindex="0">
          <div class="exr__media">
            {% if s[photo_key] %}<img src="{{ s[photo_key] | image_url: width: 600 }}" alt="{{ s[name_key] | escape }}" width="600" height="600" loading="lazy">{% else %}<img src="{{ 'image' | placeholder_svg_tag }}" alt="" width="600" height="600">{% endif %}
            <span class="exr__badge">&#8220;</span>
            <div class="exr__quote">
              <p class="exr__qtext">{{ s[quote_key] }}</p>
              <span class="exr__qby">{{ s[name_key] | escape }}</span>
            </div>
          </div>
          <div class="exr__body">
            <div class="exr__name">{{ s[name_key] | escape }}</div>
            <div class="exr__role">{{ s[role_key] | escape }}</div>
            <p class="exr__qm">{{ s[quote_key] }}</p>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script>
(function(){
  var root=document.getElementById('exr-{{ uid }}');
  if(!root || root.dataset.exrBound) return;
  root.dataset.exrBound='1';
  root.addEventListener('click',function(e){
    var card=e.target.closest('.exr__card'); if(!card) return;
    var open=card.classList.contains('is-open');
    root.querySelectorAll('.exr__card.is-open').forEach(function(c){c.classList.remove('is-open');});
    if(!open) card.classList.add('is-open');
  });
})();
</script>
