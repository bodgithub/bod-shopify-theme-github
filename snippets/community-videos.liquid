{%- comment -%}
  Bodology · Community Videos (shared render)
  Rendered as a BLOCK inside the main-product (Product information) section.

  Params:
    s   - settings object (block.settings)
    uid - unique instance id (block.id)

  Up to 12 videos are flat settings (v1_..v12_) because a Shopify block
  cannot contain repeatable sub-blocks. Tag filter chips are derived from
  the distinct tags. Optional scroll-pin mode horizontally scroll-jacks
  the cards while the section is pinned.
{%- endcomment -%}

{%- liquid
  assign sid = 'vcg-' | append: uid
  assign pin = s.scroll_pin
  assign count = 0
  for i in (1..12)
    assign nk = 'v' | append: i | append: '_name'
    assign ik = 'v' | append: i | append: '_image'
    if s[nk] != blank or s[ik] != blank
      assign count = count | plus: 1
    endif
  endfor
-%}

<style>
  #{{ sid }}{
    --blue: {{ s.accent | default: '#1B3DEF' }};
    --sec: {{ s.section_bg | default: '#16307F' }};
    --ov: {{ s.overlay | default: '#081034' }};
    --fg: {{ s.font_color | default: '#ffffff' }};
    --panel: {{ s.panel_bg | default: '#0E2160' }};
    --fs-title: {{ s.fs_title | default: 34 }}px;
    --fs-name: {{ s.fs_name | default: 19 }}px;
    --fs-role: {{ s.fs_role | default: 12 }}px;
    --fs-quote: {{ s.fs_quote | default: 13 }}px;
    --card-w: {{ s.card_width | default: 272 }}px;
    box-sizing:border-box; position:relative;
    font-family:"tenon","Helvetica Neue",Arial,sans-serif;
    background:radial-gradient(140% 130% at 18% 8%, color-mix(in srgb,var(--sec) 70%,#4a6cff) 0%, var(--sec) 54%, color-mix(in srgb,var(--sec) 72%,#000) 100%);
    padding:{{ s.pad_top | default: 54 }}px 0 {{ s.pad_bottom | default: 60 }}px;
  }
  {%- if s.section_bg_solid -%}
  #{{ sid }}{ background: {{ s.section_bg | default: '#16307F' }}; }
  {%- endif -%}
  {%- if s.full_bleed -%}
  #{{ sid }}{ width:100vw; max-width:100vw; position:relative; left:50%; right:50%; margin-left:-50vw; margin-right:-50vw; overflow-x:clip; }
  {%- endif -%}
  #{{ sid }} *, #{{ sid }} *::before, #{{ sid }} *::after{ box-sizing:border-box; }

  #{{ sid }} .vcg__head{ text-align:center; max-width:42ch; margin:0 auto 6px; padding:0 16px; }
  #{{ sid }} .vcg__eyebrow{ font-size:10.5px; font-weight:500; letter-spacing:0.18em; text-transform:uppercase; color:color-mix(in srgb,var(--fg) 64%,transparent); margin:0 0 11px; }
  #{{ sid }} .vcg__title{ font-weight:600; font-size:var(--fs-title); letter-spacing:-0.03em; line-height:1.06; color:var(--fg); margin:0; }

  #{{ sid }} .vcg__tags{ display:flex; flex-wrap:wrap; justify-content:center; gap:9px; margin:20px auto 0; padding:0 16px; }
  #{{ sid }} .vcg__tag{ font-size:12.5px; font-weight:500; color:color-mix(in srgb,var(--fg) 78%,transparent); background:transparent; border:1px solid color-mix(in srgb,var(--fg) 28%,transparent); border-radius:999px; padding:8px 17px; cursor:pointer; transition:all .16s; font-family:inherit; }
  #{{ sid }} .vcg__tag:hover{ border-color:color-mix(in srgb,var(--fg) 55%,transparent); color:var(--fg); }
  #{{ sid }} .vcg__tag.is-on{ background:var(--fg); border-color:var(--fg); color:var(--sec); }

  #{{ sid }} .vcg__view{ overflow-x:hidden; padding:26px 0 6px; touch-action:pan-y; }
  #{{ sid }} .vcg__track{ display:flex; gap:22px; padding:0 max(24px,calc((100% - 1160px)/2)); will-change:transform; user-select:none; cursor:grab; }
  #{{ sid }} .vcg__track.is-drag{ cursor:grabbing; }

  #{{ sid }} .vcg__card{ flex:0 0 var(--card-w); position:relative; border-radius:14px; overflow:hidden; background:var(--panel); box-shadow:0 22px 50px rgba(6,14,46,0.4); transition:transform .25s; }
  #{{ sid }} .vcg__card:hover{ transform:translateY(-3px); }

  #{{ sid }} .vcg__media{ position:relative; aspect-ratio:3/4; overflow:hidden; }
  #{{ sid }} .vcg__media img{ width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s, filter .3s; }
  #{{ sid }} .vcg__card:hover .vcg__media img{ transform:scale(1.04); filter:brightness(0.84); }

  #{{ sid }} .vcg__play{ position:absolute; left:50%; top:50%; transform:translate(-50%,-46%) scale(.9); width:62px; height:62px; border-radius:50%; background:rgba(255,255,255,0.94); display:flex; align-items:center; justify-content:center; z-index:4; opacity:0; pointer-events:none; transition:opacity .28s, transform .28s; box-shadow:0 10px 30px rgba(6,14,46,0.5); }
  #{{ sid }} .vcg__play svg{ width:22px; height:22px; fill:var(--blue); margin-left:3px; }
  #{{ sid }} .vcg__card:hover .vcg__play{ opacity:1; transform:translate(-50%,-50%) scale(1); }

  #{{ sid }} .vcg__scrim{ position:absolute; left:0; right:0; bottom:0; z-index:3; padding:20px 18px 18px; background:linear-gradient(to top, var(--ov) 6%, color-mix(in srgb,var(--ov) 58%,transparent) 44%, transparent 100%); transition:opacity .28s; }
  #{{ sid }} .vcg__card:hover .vcg__scrim{ opacity:0; }
  #{{ sid }} .vcg__name{ font-weight:600; font-size:var(--fs-name); line-height:1.08; color:var(--fg); margin:0 0 5px; letter-spacing:-0.01em; }
  #{{ sid }} .vcg__role{ font-weight:400; font-size:var(--fs-role); line-height:1.35; color:color-mix(in srgb,var(--fg) 80%,transparent); margin:0 0 11px; }
  #{{ sid }} .vcg__quote{ {% if s.show_quote %}display:block;{% else %}display:none;{% endif %} font-weight:400; font-size:var(--fs-quote); line-height:1.4; color:color-mix(in srgb,var(--fg) 90%,transparent); margin:0 0 12px; }
  #{{ sid }} .vcg__pill{ display:inline-block; font-size:9px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--fg); border:1px solid color-mix(in srgb,var(--fg) 50%,transparent); border-radius:999px; padding:6px 12px; }

  #{{ sid }}[data-style="split"] .vcg__media{ aspect-ratio:1/1; }
  #{{ sid }}[data-style="split"] .vcg__scrim{ position:static; background:var(--panel); padding:18px 18px 20px; opacity:1 !important; }
  #{{ sid }}[data-style="split"] .vcg__card:hover .vcg__media img{ filter:brightness(0.78); }

  #{{ sid }} .vcg__dots{ display:flex; justify-content:center; align-items:center; gap:8px; margin-top:26px; }
  #{{ sid }} .vcg__dot{ width:8px; height:8px; border-radius:50%; background:color-mix(in srgb,var(--fg) 34%,transparent); border:0; padding:0; cursor:pointer; transition:all .22s; }
  #{{ sid }} .vcg__dot.is-on{ background:var(--fg); width:26px; border-radius:999px; }

  /* Scroll-pin (scroll-jack) mode */
  #{{ sid }}.vcg--pin{ padding:0; }
  #{{ sid }}.vcg--pin .vcg__pin{ position:relative; }
  #{{ sid }}.vcg--pin .vcg__sticky{ position:sticky; top:0; min-height:100vh; display:flex; flex-direction:column; justify-content:center; padding:{{ s.pad_top | default: 54 }}px 0 {{ s.pad_bottom | default: 60 }}px; overflow:hidden; }
  #{{ sid }}.vcg--pin .vcg__view{ overflow:hidden; }
  #{{ sid }}.vcg--pin .vcg__track{ cursor:default; }
  #{{ sid }}.vcg--pin .vcg__dots{ display:none; }

  @media (max-width:560px){ #{{ sid }} .vcg__card{ flex-basis:230px; } }
</style>

<div id="{{ sid }}" class="{% if pin %}vcg--pin{% endif %}" data-style="{{ s.card_style | default: 'gradient' }}" {% if pin %}data-pin="1"{% endif %}>
  {%- capture inner -%}
  <div class="vcg__head">
    {%- if s.eyebrow != blank -%}<p class="vcg__eyebrow">{{ s.eyebrow }}</p>{%- endif -%}
    {%- if s.title != blank -%}<h2 class="vcg__title">{{ s.title }}</h2>{%- endif -%}
  </div>

  {%- if s.show_tags -%}
    {%- assign tag_list = '' -%}
    {%- for i in (1..12) -%}
      {%- assign tk = 'v' | append: i | append: '_tag' -%}
      {%- assign t = s[tk] | strip -%}
      {%- if t != blank -%}
        {%- unless tag_list contains t -%}
          {%- assign tag_list = tag_list | append: t | append: '|' -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
    <div class="vcg__tags" data-tags>
      <button class="vcg__tag is-on" data-tag="All">{{ s.all_label | default: 'All' }}</button>
      {%- assign tags = tag_list | split: '|' -%}
      {%- for t in tags -%}
        {%- if t != blank -%}<button class="vcg__tag" data-tag="{{ t }}">{{ t }}</button>{%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="vcg__view" data-view>
    <div class="vcg__track" data-track>
      {%- for i in (1..12) -%}
        {%- liquid
          assign ik = 'v' | append: i | append: '_image'
          assign nk = 'v' | append: i | append: '_name'
          assign rk = 'v' | append: i | append: '_role'
          assign qk = 'v' | append: i | append: '_quote'
          assign tk = 'v' | append: i | append: '_tag'
          assign uk = 'v' | append: i | append: '_url'
        -%}
        {%- if s[nk] != blank or s[ik] != blank -%}
          <div class="vcg__card" data-card data-tag="{{ s[tk] | strip }}">
            <div class="vcg__media">
              {%- if s[ik] != blank -%}
                <img src="{{ s[ik] | image_url: width: 700 }}" alt="{{ s[nk] | escape }}" loading="lazy" width="700" height="933">
              {%- endif -%}
              {%- if s[uk] != blank -%}
                <a class="vcg__play" href="{{ s[uk] }}" target="_blank" rel="noopener" aria-label="Play {{ s[nk] | escape }}" style="pointer-events:auto;">
                  <svg viewBox="0 0 24 24"><path d="M7 4 L20 12 L7 20 Z"/></svg>
                </a>
              {%- else -%}
                <span class="vcg__play"><svg viewBox="0 0 24 24"><path d="M7 4 L20 12 L7 20 Z"/></svg></span>
              {%- endif -%}
            </div>
            <div class="vcg__scrim">
              {%- if s[nk] != blank -%}<h3 class="vcg__name">{{ s[nk] }}</h3>{%- endif -%}
              {%- if s[rk] != blank -%}<p class="vcg__role">{{ s[rk] }}</p>{%- endif -%}
              {%- if s[qk] != blank -%}<p class="vcg__quote">{{ s[qk] }}</p>{%- endif -%}
              {%- if s[tk] != blank -%}<span class="vcg__pill">{{ s[tk] }}</span>{%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="vcg__dots" data-dots></div>
  {%- endcapture -%}

  {%- if pin -%}
    <div class="vcg__pin" data-pin-outer>
      <div class="vcg__sticky">{{ inner }}</div>
    </div>
  {%- else -%}
    {{ inner }}
  {%- endif -%}
</div>

<script>
(function(){
  var root = document.getElementById('{{ sid }}');
  if(!root || root.dataset.vcgBound) return;
  root.dataset.vcgBound='1';
  var track = root.querySelector('[data-track]');
  var view  = root.querySelector('[data-view]');
  var dotsEl= root.querySelector('[data-dots]');
  var tagsEl= root.querySelector('[data-tags]');
  var pinOuter = root.querySelector('[data-pin-outer]');
  var isPin = root.getAttribute('data-pin')==='1';
  var allCards = [].slice.call(track.querySelectorAll('[data-card]'));
  var page=0, cur=0, step=0, filter='All';
  function gap(){ return 22; }
  function visible(){ return allCards.filter(function(c){ return c.style.display!=='none'; }); }

  if(tagsEl){
    tagsEl.addEventListener('click', function(e){
      var b=e.target.closest('.vcg__tag'); if(!b) return;
      filter=b.getAttribute('data-tag');
      [].forEach.call(tagsEl.children,function(c){ c.classList.toggle('is-on', c===b); });
      allCards.forEach(function(c){
        c.style.display = (filter==='All' || c.getAttribute('data-tag')===filter) ? '' : 'none';
      });
      page=0;
      if(isPin){ sizePin(); onScroll(); } else { buildDots(); go(false); }
    });
  }

  /* ---- scroll-pin (scroll-jack) mode ---- */
  function maxOff(){ return Math.min(0, view.clientWidth - track.scrollWidth); }
  function sizePin(){
    if(!pinOuter) return;
    var dist = -maxOff();                       // horizontal travel needed
    pinOuter.style.height = (window.innerHeight + dist) + 'px';
  }
  function onScroll(){
    if(!pinOuter) return;
    var rect = pinOuter.getBoundingClientRect();
    var total = pinOuter.offsetHeight - window.innerHeight;
    var prog = total>0 ? Math.min(1, Math.max(0, (-rect.top)/total)) : 0;
    var off = maxOff()*prog;
    track.style.transition='none';
    track.style.transform='translateX('+off+'px)';
  }

  /* ---- drag + dots mode ---- */
  function per(){ var v=visible(); if(!v.length) return 1; return Math.max(1, Math.round(view.clientWidth/(v[0].offsetWidth+gap()))); }
  function pages(){ return Math.max(1, visible().length - per() + 1); }
  function buildDots(){
    if(!dotsEl) return;
    dotsEl.innerHTML=''; var n=pages(); if(n<=1) return;
    for(var i=0;i<n;i++){ (function(i){
      var b=document.createElement('button'); b.className='vcg__dot'+(i===page?' is-on':'');
      b.onclick=function(){ page=i; go(); }; dotsEl.appendChild(b);
    })(i); }
  }
  function go(snap){
    var v=visible(); if(!v.length) return;
    page=Math.max(0, Math.min(page, pages()-1));
    step=v[0].offsetWidth+gap();
    var off=Math.max(maxOff(), -(page*step));
    track.style.transition = snap===false ? 'none' : 'transform .5s cubic-bezier(.2,.7,.2,1)';
    track.style.transform='translateX('+off+'px)'; cur=off;
    if(dotsEl)[].forEach.call(dotsEl.children,function(c,i){ c.classList.toggle('is-on', i===page); });
  }

  if(isPin){
    sizePin(); onScroll();
    window.addEventListener('scroll', onScroll, { passive:true });
    window.addEventListener('resize', function(){ sizePin(); onScroll(); });
  } else {
    var dragging=false,sx=0,base=0,moved=false;
    view.addEventListener('pointerdown',function(e){ dragging=true; moved=false; sx=e.clientX; base=cur; track.classList.add('is-drag'); track.style.transition='none'; view.setPointerCapture(e.pointerId); });
    view.addEventListener('pointermove',function(e){ if(!dragging)return; var dx=e.clientX-sx; if(Math.abs(dx)>4)moved=true; track.style.transform='translateX('+(base+dx)+'px)'; cur=base+dx; });
    function end(){ if(!dragging)return; dragging=false; track.classList.remove('is-drag'); if(moved){ var v=visible(); step=v[0].offsetWidth+gap(); page=Math.round(-cur/step); } go(); }
    view.addEventListener('pointerup',end); view.addEventListener('pointercancel',end);
    view.addEventListener('click',function(e){ if(moved){ e.preventDefault(); e.stopPropagation(); } },true);
    buildDots(); go(false);
    window.addEventListener('resize',function(){ buildDots(); go(false); });
  }
})();
</script>
